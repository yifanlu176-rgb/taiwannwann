---
import '../styles/tokens.css';
import '../styles/reset.css';
import '../styles/base.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  locale: 'ja' | 'zh';
  canonicalPath: string;
}

const { title, description, locale, canonicalPath } = Astro.props;

/* Umami analytics — set env vars to enable */
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;   // e.g. https://umami.example.com
const umamiId = import.meta.env.PUBLIC_UMAMI_ID;      // website ID from Umami dashboard

const config = {
  ja: { htmlLang: 'ja', ogLocale: 'ja_JP', skipLabel: '本文へスキップ' },
  zh: { htmlLang: 'zh-TW', ogLocale: 'zh_TW', skipLabel: '跳至主要內容' },
} as const;

const { htmlLang, ogLocale, skipLabel } = config[locale];

const siteUrl = 'https://taiwannwann.co.jp';
const canonicalUrl = `${siteUrl}${canonicalPath}`;

/* JSON-LD: Organization + WebSite (rendered on every page) */
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      'name': '太旺旺株式会社',
      'alternateName': 'Taiwannwann Co., Ltd.',
      'url': siteUrl,
      'logo': `${siteUrl}/favicon.svg`,
      'address': {
        '@type': 'PostalAddress',
        'streetAddress': '深江北 2-1-3',
        'addressLocality': '大阪市東成区',
        'addressRegion': '大阪府',
        'postalCode': '537-0002',
        'addressCountry': 'JP',
      },
      'founder': {
        '@type': 'Person',
        'name': '楊 杰敏',
      },
      'foundingDate': '2024',
      'sameAs': [],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      'url': siteUrl,
      'name': '太旺旺株式会社',
      'publisher': { '@id': `${siteUrl}/#organization` },
      'inLanguage': ['ja', 'zh-TW'],
    },
  ],
};
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f7f2ea" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="ja" href={`${siteUrl}/ja/`} />
    <link rel="alternate" hreflang="zh-TW" href={`${siteUrl}/zh/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/ja/`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="太旺旺株式会社" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&family=Noto+Serif+TC:wght@300;400;500;600&family=Cormorant+Garamond:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    {umamiUrl && umamiId && (
      <script is:inline defer src={`${umamiUrl}/script.js`} data-website-id={umamiId}></script>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">{skipLabel}</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
