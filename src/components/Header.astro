---
interface Props {
  locale: 'ja' | 'zh';
}

const { locale } = Astro.props;

const t = {
  ja: {
    brandAria: '太旺旺ホーム',
    navAria: 'メインナビゲーション',
    nav: [
      { href: '#about', label: '私たちのこと' },
      { href: '#products', label: '商品' },
      { href: '#contact', label: 'お問い合わせ' },
    ],
    switch: { label: '繁體中文', path: '/zh/' },
  },
  zh: {
    brandAria: '太旺旺 首頁',
    navAria: '主要選單',
    nav: [
      { href: '#about', label: '關於我們' },
      { href: '#products', label: '商品' },
      { href: '#contact', label: '聯絡我們' },
    ],
    switch: { label: '日本語', path: '/ja/' },
  },
} as const;

const localeT = t[locale];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href={`/${locale}/`} class="site-header__brand" aria-label={localeT.brandAria}>
      <span class="brand-mark">太旺旺</span>
    </a>
    <nav class="site-header__nav" aria-label={localeT.navAria}>
      {localeT.nav.map(item => (
        <a href={`/${locale}/${item.href}`}>{item.label}</a>
      ))}
    </nav>
    <a href={localeT.switch.path} class="lang-switch">{localeT.switch.label}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: var(--z-sticky);
    background: rgba(247, 242, 234, 0.9);
    backdrop-filter: blur(8px);
    border-block-end: 1px solid var(--border-subtle);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    block-size: 64px;
  }

  .site-header__brand {
    color: var(--text-primary);
  }

  .brand-mark {
    font-family: var(--font-ja);
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    letter-spacing: 0.06em;
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-6);
  }

  .site-header__nav a {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    transition: color var(--duration-instant) var(--ease-smooth);
  }

  .site-header__nav a:hover {
    color: var(--text-primary);
  }

  .lang-switch {
    font-family: var(--font-latin);
    font-size: var(--fs-body-sm);
    color: var(--text-link);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xs);
    transition: color var(--duration-quick) var(--ease-smooth),
                border-color var(--duration-quick) var(--ease-smooth);
  }

  .lang-switch:hover {
    color: var(--accent-primary);
    border-color: var(--border-accent);
  }

  @media (max-width: 768px) {
    .site-header__nav {
      display: none;
    }
  }
</style>
