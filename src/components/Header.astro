---
interface Props {
  locale: 'ja' | 'zh';
}

const { locale } = Astro.props;

const t = {
  ja: {
    brandAria: '太旺旺ホーム',
    navAria: 'メインナビゲーション',
    menuLabel: 'メニューを開く',
    closeLabel: 'メニューを閉じる',
    nav: [
      { href: '#about', label: '私たちのこと' },
      { href: '#products', label: '商品' },
      { href: '/ja/faq/', label: 'FAQ' },
      { href: '#contact', label: 'お問い合わせ' },
    ],
    switch: { label: '繁體中文', path: '/zh/' },
  },
  zh: {
    brandAria: '太旺旺 首頁',
    navAria: '主要選單',
    menuLabel: '開啟選單',
    closeLabel: '關閉選單',
    nav: [
      { href: '#about', label: '關於我們' },
      { href: '#products', label: '商品' },
      { href: '/zh/faq/', label: 'FAQ' },
      { href: '#contact', label: '聯絡我們' },
    ],
    switch: { label: '日本語', path: '/ja/' },
  },
} as const;

const localeT = t[locale];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href={`/${locale}/`} class="site-header__brand" aria-label={localeT.brandAria}>
      <span class="brand-mark">太旺旺</span>
    </a>

    <nav class="site-header__nav" id="site-nav" aria-label={localeT.navAria}>
      {localeT.nav.map(item => (
        <a href={item.href.startsWith('/') ? item.href : `/${locale}/${item.href}`}>{item.label}</a>
      ))}
      <a href={localeT.switch.path} class="lang-switch lang-switch--mobile">{localeT.switch.label}</a>
    </nav>

    <div class="site-header__actions">
      <a href={localeT.switch.path} class="lang-switch lang-switch--desktop">{localeT.switch.label}</a>
      <button
        class="menu-toggle"
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="site-nav"
        aria-label={localeT.menuLabel}
        data-close-label={localeT.closeLabel}
        data-open-label={localeT.menuLabel}
      >
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('site-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('is-open', !open);
      toggle.setAttribute('aria-label',
        open ? toggle.dataset.openLabel! : toggle.dataset.closeLabel!
      );
    });
    nav.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'A' && target.getAttribute('href')?.startsWith('#')) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-label', toggle.dataset.openLabel!);
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: var(--z-sticky);
    background: rgba(247, 242, 234, 0.9);
    backdrop-filter: blur(8px);
    border-block-end: 1px solid var(--border-subtle);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    block-size: 64px;
  }

  .site-header__brand {
    color: var(--text-primary);
  }

  .brand-mark {
    font-family: var(--font-ja);
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    letter-spacing: 0.06em;
  }

  /* Desktop nav */
  .site-header__nav {
    display: flex;
    gap: var(--space-6);
  }

  .site-header__nav a {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    transition: color var(--duration-instant) var(--ease-smooth);
  }

  .site-header__nav a:hover {
    color: var(--text-primary);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .lang-switch {
    font-family: var(--font-latin);
    font-size: var(--fs-body-sm);
    color: var(--text-link);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xs);
    transition: color var(--duration-quick) var(--ease-smooth),
                border-color var(--duration-quick) var(--ease-smooth);
    white-space: nowrap;
  }

  .lang-switch:hover {
    color: var(--accent-primary);
    border-color: var(--border-accent);
  }

  .lang-switch--mobile {
    display: none;
  }

  /* Hamburger button */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .menu-toggle__bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform var(--duration-quick) var(--ease-smooth),
                opacity var(--duration-quick) var(--ease-smooth);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle__bar:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle__bar:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    .lang-switch--desktop {
      display: none;
    }

    .site-header__nav {
      display: none;
      position: absolute;
      inset-block-start: 64px;
      inset-inline: 0;
      background: rgba(247, 242, 234, 0.98);
      backdrop-filter: blur(12px);
      border-block-end: 1px solid var(--border-subtle);
      padding: var(--space-5) var(--section-padding-x) var(--space-6);
      flex-direction: column;
      gap: var(--space-4);
    }

    .site-header__nav.is-open {
      display: flex;
    }

    .site-header__nav a {
      font-size: var(--fs-body);
      padding-block: var(--space-2);
    }

    .lang-switch--mobile {
      display: inline-block;
      align-self: flex-start;
      margin-block-start: var(--space-3);
    }
  }
</style>
